# =============================================================================
# HappySpeech — .gitignore
# =============================================================================
# Repository contains ONLY the iOS app source + Xcode project + Cloud Functions.
# Local dev tooling, AI-agent configs, design experiments, datasets, screenshots,
# logs, and secrets stay on the developer's machine, never on GitHub.

# ---------- macOS ----------
.DS_Store
**/.DS_Store
*.swp
*.swo

# ---------- Xcode ----------
build/
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
xcuserdata/
*.moved-aside
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xccheckout
*.xcarchive/
*.xcresult
dist/

# ---------- Swift Package Manager ----------
.swiftpm/
Package.resolved
.build/
Packages/

# ---------- CocoaPods (project doesn't use, but defensive) ----------
Pods/

# ---------- Firebase ----------
# GoogleService-Info.plist contains app-specific Firebase keys; the project's
# Firebase project is owner-bound and not shared. Each developer adds their own.
GoogleService-Info.plist
.firebase/
firebase-debug.log
firebase-debug.*.log
ui-debug.log
functions/node_modules/
functions/.runtimeconfig.json
functions/lib/

# ---------- Python (ML pipeline lives in ~/Downloads/HappySpeech/_workshop/) ----------
*.pyc
__pycache__/
venv/
.venv/
*.egg-info/

# ---------- ML training artifacts (NEVER commit) ----------
# Datasets, raw audio, checkpoints — all in ~/Downloads/HappySpeech/_workshop/.
# Only final .mlpackage files are committed under HappySpeech/Resources/Models/.
_workshop/
*.mlpackage/DerivedData/

# ---------- Local design experiments ----------
# Local design prototypes / mockups / brand experiments — not project source.
happyspeech-design/

# ---------- AI-agent configs (developer-local) ----------
# Claude Code config — local-only orchestration, not part of the iOS app.
.claude/
# Also ignore any AI-agent or LLM auxiliary tooling lying around the repo.
.cursor/
.aider*
.codeium/

# ---------- Temp / scratch ----------
tmp/
.tmp/
*.tmp
scratch/

# ---------- Logs ----------
*.log

# ---------- Env / secrets ----------
.env
.env.local
.env.*.local
*.pem
*.p12
*.cer

# ---------- Screenshots / QA artifacts (regenerable) ----------
docs/screenshots/
docs/screenshots-*/
_screenshots/
sounds/

# ---------- Editor / IDE ----------
.idea/
.vscode/
*.iml

# ---------- Misc ----------
*~
.envrc
