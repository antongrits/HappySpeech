    "settings.privacy.body": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "HappySpeech не передаёт данные третьим лицам и не использует рекламные сети. Все данные хранятся на устройстве и синхронизируются только с вашим аккаунтом Firebase."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HappySpeech does not share data with third parties and does not use advertising networks. All data is stored on-device and syncs only with your Firebase account."
          }
        }
      }
    },
