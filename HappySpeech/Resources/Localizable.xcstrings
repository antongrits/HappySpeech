    "helpCenter.category.privacy": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приватность и безопасность"
          }
        }
      }
    },
    "helpCenter.faq.gs1.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как начать первое занятие?"
          }
        }
      }
    },
    "helpCenter.faq.gs1.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте профиль ребёнка на главном экране и нажмите «Начать занятие». Приложение предложит подходящий сценарий на основе возраста и предыдущих сессий."
          }
        }
      }
    },
    "helpCenter.faq.gs2.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сколько длится одно занятие?"
          }
        }
      }
    },
    "helpCenter.faq.gs2.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Длительность подбирается под возраст: 5–6 лет — 7–10 минут, 6–7 лет — 10–12 минут, 7–8 лет — 12–15 минут. Можно остановиться в любой момент."
          }
        }
      }
    },
    "helpCenter.faq.gs3.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Какие звуки можно отрабатывать?"
          }
        }
      }
    },
    "helpCenter.faq.gs3.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сейчас доступны 4 группы: свистящие (С, З, Ц), шипящие (Ш, Ж, Ч, Щ), соноры (Р, Л) и заднеязычные (К, Г, Х)."
          }
        }
      }
    },
    "helpCenter.faq.vr1.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Почему приложение не слышит ребёнка?"
          }
        }
      }
    },
    "helpCenter.faq.vr1.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверьте разрешение на доступ к микрофону в Настройках iPhone. Уберите фоновый шум и попросите ребёнка говорить ближе к устройству."
          }
        }
      }
    },
    "helpCenter.faq.vr2.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Распознавание работает без интернета?"
          }
        }
      }
    },
    "helpCenter.faq.vr2.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Да. Распознавание речи полностью выполняется на устройстве через WhisperKit. Интернет не нужен."
          }
        }
      }
    },
    "helpCenter.faq.vr3.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Можно ли тренироваться в шумном месте?"
          }
        }
      }
    },
    "helpCenter.faq.vr3.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лучше выбрать тихое место — это помогает приложению точнее оценить произношение и снижает усталость ребёнка."
          }
        }
      }
    },
    "helpCenter.faq.pr1.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Где посмотреть прогресс?"
          }
        }
      }
    },
    "helpCenter.faq.pr1.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В разделе «Родителю» → «Прогресс». Там собрана статистика за неделю, месяц и квартал по каждому ребёнку."
          }
        }
      }
    },
    "helpCenter.faq.pr2.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Можно ли экспортировать отчёт для логопеда?"
          }
        }
      }
    },
    "helpCenter.faq.pr2.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Да. В разделе «Прогресс» нажмите «Экспорт PDF» — отчёт будет сохранён в Файлы и его можно отправить специалисту."
          }
        }
      }
    },
    "helpCenter.faq.pc1.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как ограничить время использования?"
          }
        }
      }
    },
    "helpCenter.faq.pc1.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Воспользуйтесь Экранным временем в Настройках iPhone. Приложение также показывает напоминание о паузе после 15 минут занятия."
          }
        }
      }
    },
    "helpCenter.faq.pc2.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Можно ли отключить покупки внутри приложения?"
          }
        }
      }
    },
    "helpCenter.faq.pc2.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В приложении нет встроенных покупок и рекламы — оно полностью соответствует требованиям Kids Category."
          }
        }
      }
    },
    "helpCenter.faq.pv1.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Какие данные собирает приложение?"
          }
        }
      }
    },
    "helpCenter.faq.pv1.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только локальные данные о прогрессе ребёнка. Голосовые записи не отправляются на сервер — все вычисления делаются на устройстве."
          }
        }
      }
    },
    "helpCenter.faq.pv2.question": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что соответствует COPPA?"
          }
        }
      }
    },
    "helpCenter.faq.pv2.answer": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложение разработано в соответствии с COPPA: нет рекламы, нет сторонних трекеров, нет персонализированных рекомендаций для детей младше 13 лет."
          }
        }
      }
    },
    "helpCenter.video.section.title": {
      "extractionState": "manual",
      "localizations": {
