    "helpCenter.video.progressTracking.description": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как читать графики и интерпретировать отчёт."
          }
        }
      }
    },
    "helpCenter.contact.title": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Связаться с логопедом"
          }
        }
      }
    },
    "helpCenter.contact.description": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задайте вопрос специалисту прямо из приложения — бесплатно для родителей."
          }
        }
      }
    },
    "helpCenter.contact.cta": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открыть чат с логопедом"
          }
        }
      }
    },
    "helpCenter.contact.hint": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откроется внутренний чат с логопедом"
          }
        }
      }
    },
    "helpCenter.contact.toast.opened": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открываем чат с логопедом..."
          }
        }
      }
    },
    "helpCenter.contact.toast.failed": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось открыть чат"
          }
        }
      }
    },
    "soundDictionary.phoneme.vow-a.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широко откройте рот, расслабьте язык — он лежит плоско."
          }
        }
      }
    },
    "soundDictionary.phoneme.vow-o.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Округлите губы, как будто хотите подуть на свечу."
          }
        }
      }
    },
    "soundDictionary.phoneme.vow-u.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вытяните губы трубочкой — короткое сильное «у»."
          }
        }
      }
    },
    "soundDictionary.phoneme.vow-e.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слегка растяните губы, кончик языка касается нижних зубов."
          }
        }
      }
    },
    "soundDictionary.phoneme.vow-i.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широкая улыбка, язык приподнимается к нёбу."
          }
        }
      }
    },
    "soundDictionary.phoneme.vow-y.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Губы напряжены, язык отодвинут назад — звук между «и» и «у»."
          }
        }
      }
    },
    "soundDictionary.phoneme.wh-s.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Зубы сомкнуты заборчиком, по середине языка идёт холодная струйка воздуха."
          }
        }
      }
    },
    "soundDictionary.phoneme.wh-s-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тот же С, но средняя часть языка приподнята к нёбу."
          }
        }
      }
    },
    "soundDictionary.phoneme.wh-z.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как С, но голосовые связки работают — приложите руку к горлу и почувствуйте дрожь."
          }
        }
      }
    },
    "soundDictionary.phoneme.wh-z-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий З: язык приподнят, голос звонкий."
          }
        }
      }
    },
    "soundDictionary.phoneme.wh-ts.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слитный звук: сначала Т, потом мгновенно С."
          }
        }
      }
    },
    "soundDictionary.phoneme.hs-sh.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Губы округлены и выдвинуты вперёд, язык поднят чашечкой к нёбу."
          }
        }
      }
    },
    "soundDictionary.phoneme.hs-zh.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тот же Ш, но с голосом — почувствуйте дрожь в горле."
          }
        }
      }
    },
    "soundDictionary.phoneme.hs-ch.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слитный звук: Ть и Щ произносятся одновременно."
          }
        }
      }
    },
    "soundDictionary.phoneme.hs-shch.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Долгий мягкий звук, язык широко прижат к верхним зубам."
          }
        }
      }
    },
    "soundDictionary.phoneme.son-r.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кончик языка вибрирует за верхними зубами под сильной струёй воздуха."
          }
        }
      }
    },
    "soundDictionary.phoneme.son-r-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий Р: средняя часть языка приподнята, вибрация легче."
          }
        }
      }
    },
    "soundDictionary.phoneme.son-l.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кончик языка упирается в верхние зубы, бока опущены."
          }
        }
      }
    },
    "soundDictionary.phoneme.son-l-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тот же Л, но язык приподнят к нёбу."
          }
        }
      }
    },
    "soundDictionary.phoneme.vel-k.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задняя часть языка смыкается с мягким нёбом — короткий «взрыв»."
          }
        }
      }
    },
    "soundDictionary.phoneme.vel-k-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "К с приподнятой средней частью языка — звучит мягко."
          }
        }
      }
    },
    "soundDictionary.phoneme.vel-g.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как К, но со звонким голосом."
          }
        }
      }
    },
    "soundDictionary.phoneme.vel-g-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий Г: язык приподнят, голос звонкий."
          }
        }
      }
    },
    "soundDictionary.phoneme.vel-h.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задняя часть языка приподнимается, воздух проходит с шумом — выдох."
          }
        }
      }
    },
    "soundDictionary.phoneme.vel-h-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тот же Х, но язык чуть выше и звук мягче."
          }
        }
      }
    },
    "soundDictionary.phoneme.nas-m.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Губы сомкнуты, воздух идёт через нос. Голос есть."
          }
        }
      }
    },
    "soundDictionary.phoneme.nas-m-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тот же М, средняя часть языка приподнята."
          }
        }
      }
    },
    "soundDictionary.phoneme.nas-n.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кончик языка касается верхних зубов, воздух выходит через нос."
          }
        }
      }
    },
    "soundDictionary.phoneme.nas-n-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий Н: язык чуть выше, звук теплее."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-b.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сомкнутые губы размыкаются, голос работает — звонкий «взрыв»."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-b-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий Б: губы расслаблены, средняя часть языка вверх."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-p.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сомкнутые губы размыкаются без голоса — глухой «хлопок»."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-p-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий П: губы расслаблены, язык приподнят."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-v.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нижняя губа лёгкое касание верхних зубов, голос работает."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-v-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий В: губы расслаблены, средняя часть языка вверх."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-f.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нижняя губа касается верхних зубов, голоса нет — только шум воздуха."
          }
        }
      }
    },
    "soundDictionary.phoneme.lab-f-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий Ф: губы расслаблены, средняя часть языка вверх."
          }
        }
      }
    },
    "soundDictionary.phoneme.den-t.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кончик языка касается верхних зубов и резко опускается — глухой «стук»."
          }
        }
      }
    },
    "soundDictionary.phoneme.den-t-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий Т: язык приподнят к нёбу."
          }
        }
      }
    },
    "soundDictionary.phoneme.den-d.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как Т, но со звонким голосом."
          }
        }
      }
    },
    "soundDictionary.phoneme.den-d-soft.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мягкий Д: язык приподнят к нёбу, голос работает."
          }
        }
      }
    },
    "soundDictionary.phoneme.gli-j.articulation": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кончик языка приподнимается к верхним зубам, средняя часть — к нёбу."
          }
        }
      }
    }
  },
  "version": "1.0"
}
