    "ar.tutorial.arMirror.body": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смотри на своё лицо в экране и повторяй движения Ляли. AR-камера отслеживает артикуляцию в реальном времени."
          }
        }
      }
    },
    "ar.tutorial.arMirror.step1": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поверни телефон фронтальной камерой к себе"
          }
        }
      }
    },
    "ar.tutorial.arMirror.step2": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторяй движения губ и языка за Лялей"
          }
        }
      }
    },
    "ar.tutorial.arMirror.step3": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получи звёздочку за каждую правильную позу!"
          }
        }
      }
    },
    "ar.tutorial.arMirror.title": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Артикуляционное зеркало"
          }
        }
      }
    },
    "ar.tutorial.arStoryQuest.body": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помоги Ляле рассказать историю! Произноси слова и используй артикуляцию, чтобы двигаться по сюжету."
          }
        }
      }
    },
    "ar.tutorial.arStoryQuest.step1": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Направь камеру на своё лицо"
          }
        }
      }
    },
    "ar.tutorial.arStoryQuest.step2": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слушай историю и говори нужные слова"
          }
        }
      }
    },
    "ar.tutorial.arStoryQuest.step3": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помоги Ляле дойти до финала!"
          }
        }
      }
    },
    "ar.tutorial.arStoryQuest.title": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "AR-квест: История"
          }
        }
      }
    },
    "ar.tutorial.breathingAR.body": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дуй на одуванчик или надувай облако! AR видит твоё дыхание по движению щёк."
          }
        }
      }
    },
    "ar.tutorial.breathingAR.step1": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
