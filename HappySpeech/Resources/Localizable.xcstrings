    "settings.about.privacyPolicy.body": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "HappySpeech не передаёт данные третьим лицам и не использует рекламные сети. Все данные хранятся на устройстве и синхронизируются только с вашим аккаунтом Firebase. Аудиозаписи попыток обрабатываются локально и не передаются в облако без вашего согласия."
          }
        }
      }
    },
    "settings.about.terms": {
