    "offline.title": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет подключения к интернету"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No internet connection"
          }
        }
      }
    },
    "offline.body": {
      "extractionState": "manual",
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложение работает офлайн. Занятия доступны. Данные синхронизируются автоматически, когда интернет появится."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app works offline. Lessons are available. Data will sync automatically when you are back online."
          }
        }
      }
    },
