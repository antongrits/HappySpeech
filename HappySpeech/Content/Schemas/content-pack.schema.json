{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HappySpeech Content Pack",
  "description": "Declarative pack describing exercises for a single sound or thematic domain across correction stages.",
  "type": "object",
  "required": ["id", "soundTarget", "group", "version", "stages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(sound|pack)_[a-z][a-z0-9_]*_v[0-9]+$",
      "description": "Unique pack identifier. Sound packs: sound_<letter>_v<N>. Thematic packs: pack_<slug>_v<N>."
    },
    "soundTarget": { "type": "string", "description": "Cyrillic letter(s) or thematic key, e.g. 'С', 'Ш', 'Р', 'lexical', 'дыхание'." },
    "group": {
      "type": "string",
      "enum": [
        "свистящие",
        "шипящие",
        "соноры",
        "заднеязычные",
        "дифференциация",
        "фонематика",
        "грамматика",
        "лексика",
        "нарративный",
        "артикуляция",
        "дыхание"
      ]
    },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "stages": {
      "type": "object",
      "description": "Map of stageId -> StageDefinition. Sound packs use CorrectionStage keys; thematic packs use domain-specific keys.",
      "patternProperties": {
        "^(prep|isolated|syllable|wordInit|wordMed|wordFinal|phrase|sentence|story|diff|plural|adjective_agreement|prepositions|verb_forms|verbs|cases|grammar_cases|word_change|sentences_grammar|vowel_consonant|hard_soft|voiced_unvoiced|sound_position|syllable_count|first_sound|last_sound|minimal_pairs|sound_analysis|phonemic_games|stress_syllable|word_building|rhymes_extended|sound_substitution|animals_wild|animals_domestic|birds|insects|transport|food|food_eating|clothing|clothes|house|house_furniture|body|body_parts|nature|nature_plants|seasons|seasons_weather|vegetables|vegetables_fruits|fruits|professions|toys|toys_play|colors|colors_shapes|numbers|family|family_relations|antonyms|synonyms|school_items|emotions|voice_warmup|quest_forest|quest_sea|quest_city|quest_farm|quest_magic|quest_space|retelling|description|quest_animals|quest_home|quest_seasons|soundimitation|mini_stories|dialogue)$": {
          "$ref": "#/definitions/Stage"
        }
      },
      "additionalProperties": false
    },
    "templateCompatibility": {
      "type": "object",
      "description": "Optional override: stageId -> allowed template ids."
    }
  },
  "definitions": {
    "Stage": {
      "type": "object",
      "required": ["stageId", "items"],
      "properties": {
        "stageId": { "type": "string" },
        "note": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/Item" },
          "minItems": 1
        }
      }
    },
    "Item": {
      "type": "object",
      "required": ["id", "word", "difficulty"],
      "properties": {
        "id": { "type": "string" },
        "word": { "type": "string" },
        "imageAsset": { "type": ["string", "null"] },
        "audioAsset": { "type": ["string", "null"] },
        "hint": { "type": ["string", "null"] },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    }
  }
}
