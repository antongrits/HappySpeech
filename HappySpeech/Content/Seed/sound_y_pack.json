          "word": "Ёж живёт в лесу под ёлкой.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-2.m4a"
        },
        {
          "id": "y-sen-3",
          "word": "Юла крутится на столе.",
          "difficulty": 2,
          "audio_file": "Audio/Content/Y/y-sen-3.m4a"
        },
        {
          "id": "y-sen-4",
          "word": "Воробей поёт на скамейке.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-4.m4a"
        },
        {
          "id": "y-sen-5",
          "word": "Соловей поёт в саду.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-5.m4a"
        },
        {
          "id": "y-sen-6",
          "word": "Чайник закипел на плите.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-6.m4a"
        },
        {
          "id": "y-sen-7",
          "word": "Маша поливает цветы лейкой.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-7.m4a"
        },
        {
          "id": "y-sen-8",
          "word": "В музее много красивых картин.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-8.m4a"
        },
        {
          "id": "y-sen-9",
          "word": "Якорь держит яхту у берега.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-9.m4a"
        },
        {
          "id": "y-sen-10",
          "word": "Ягуар — быстрый и пятнистый хищник.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-10.m4a"
        },
        {
          "id": "y-sen-11",
          "word": "Юнга помогает морякам на корабле.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-11.m4a"
        },
        {
          "id": "y-sen-12",
          "word": "В январе выпало много снега.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-12.m4a"
        },
        {
          "id": "y-sen-13",
          "word": "Ёжик нашёл яблоко под ёлкой.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-13.m4a"
        },
        {
          "id": "y-sen-14",
          "word": "Яркая юбка лежит на скамейке.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-14.m4a"
        },
        {
          "id": "y-sen-15",
          "word": "Ёжик катит яблоко на спине.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-15.m4a"
        },
        {
          "id": "y-sen-16",
          "word": "Яйцо лежит в гнезде на ветке.",
          "difficulty": 2,
          "audio_file": "Audio/Content/Y/y-sen-16.m4a"
        },
        {
          "id": "y-sen-17",
          "word": "Трамвай едет по улице.",
          "difficulty": 2,
          "audio_file": "Audio/Content/Y/y-sen-17.m4a"
        },
        {
          "id": "y-sen-18",
          "word": "Попугай кричит: «Привет! Привет!»",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-18.m4a"
        },
        {
          "id": "y-sen-19",
          "word": "Зайчик сидит под кустом.",
          "difficulty": 2,
          "audio_file": "Audio/Content/Y/y-sen-19.m4a"
        },
        {
          "id": "y-sen-20",
          "word": "Ягнёнок бегает по лугу.",
          "difficulty": 2,
          "audio_file": "Audio/Content/Y/y-sen-20.m4a"
        },
        {
          "id": "y-sen-21",
          "word": "Соловей поёт красиво в саду.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-21.m4a"
        },
        {
          "id": "y-sen-22",
          "word": "Яхта плывёт по синему морю.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-22.m4a"
        },
        {
          "id": "y-sen-23",
          "word": "Чай с лимоном согревает в мороз.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-23.m4a"
        },
        {
          "id": "y-sen-24",
          "word": "Урожай яблок в этом году большой.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-24.m4a"
        },
        {
          "id": "y-sen-25",
          "word": "Юный художник рисует ёлку.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-25.m4a"
        },
        {
          "id": "y-sen-26",
          "word": "Якорь держит лодку у берега.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-26.m4a"
        },
        {
          "id": "y-sen-27",
          "word": "Яркие огни украшают ёлочку.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-27.m4a"
        },
        {
          "id": "y-sen-28",
          "word": "Ёж нашёл яблоко и яблоню.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-28.m4a"
        },
        {
          "id": "y-sen-29",
          "word": "Маша поливает яблоню из лейки.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-29.m4a"
        },
        {
          "id": "y-sen-30",
          "word": "Чайка кричит над морем.",
          "difficulty": 2,
          "audio_file": "Audio/Content/Y/y-sen-30.m4a"
        },
        {
          "id": "y-sen-31",
          "word": "Майка намокла под дождём.",
          "difficulty": 2,
          "audio_file": "Audio/Content/Y/y-sen-31.m4a"
        },
        {
          "id": "y-sen-32",
          "word": "Январь — самый холодный месяц.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-32.m4a"
        },
        {
          "id": "y-sen-33",
          "word": "Ягуар прыгнул высоко.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-33.m4a"
        },
        {
          "id": "y-sen-34",
          "word": "В музее стоят красивые картины.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-34.m4a"
        },
        {
          "id": "y-sen-35",
          "word": "Воробей клюёт зёрна на скамейке.",
          "difficulty": 3,
          "audio_file": "Audio/Content/Y/y-sen-35.m4a"
        },
        {
          "id": "y-sen-36",
          "word": "Юная певица поёт красивую песню.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-36.m4a"
        },
        {
          "id": "y-sen-37",
          "word": "Юнга смотрит в подзорную трубу.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-37.m4a"
        },
        {
          "id": "y-sen-38",
          "word": "Зайчонок прыгнул в ямку под ёлкой.",
          "difficulty": 4,
          "audio_file": "Audio/Content/Y/y-sen-38.m4a"
        },
        {
          "id": "y-sen-39",
          "word": "Ёлочка украшена яркими игрушками.",
          "difficulty": 4,
