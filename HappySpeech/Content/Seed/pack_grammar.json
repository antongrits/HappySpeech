        { "id": "gr-prep-10", "word": "где мышка? — ПОД сыром","hint": "Где? Под сыром! Мышка под сыром снизу.", "difficulty": 1 },
        { "id": "gr-prep-11", "word": "где самолёт? — НАД облаком", "hint": "Где? Над облаком! Самолёт выше облака.", "difficulty": 2 },
