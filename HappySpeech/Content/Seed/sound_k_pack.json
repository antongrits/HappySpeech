{
  "id": "sound_k_v1",
  "soundTarget": "К",
  "group": "заднеязычные",
  "version": 1,
  "description": "Коррекция звука [К] и мягкого [К'] — подготовка, изолированный звук, слоги, слова по позициям, фразы, предложения, дифференциация.",
  "stages": {
    "prep": {
      "stageId": "prep",
      "note": "Артикуляционная гимнастика для постановки заднеязычных звуков. Цель — поднять корень языка к мягкому нёбу.",
      "items": [
        { "id": "k-prep-0",  "word": "горка",              "hint": "Широко открой рот. Поднимай корень языка вверх, к нёбу, как горка. Кончик языка внизу.", "difficulty": 1 },
        { "id": "k-prep-1",  "word": "тихий кашель",       "hint": "Тихонько покашляй: кх-кх-кх. Чувствуй, как корень языка касается нёба.", "difficulty": 1 },
        { "id": "k-prep-2",  "word": "пьём горькое",       "hint": "Представь, что выпил горькое лекарство. Сморщи горло, почувствуй сжатие в глубине.", "difficulty": 2 },
        { "id": "k-prep-3",  "word": "полоскание",         "hint": "Откинь голову назад, представь, что полощешь горло водой. Р-р-р в глубине горла.", "difficulty": 2 },
        { "id": "k-prep-4",  "word": "кошечка пьёт",       "hint": "Выгни язычок назад, будто кошка лакает молочко из миски.", "difficulty": 2 },
        { "id": "k-prep-5",  "word": "улыбка-трубочка",    "hint": "Чередуй: широкая улыбка — трубочка. Разминка для губ перед работой языка.", "difficulty": 1 },
        { "id": "k-prep-6",  "word": "лопатка",            "hint": "Широкий расслабленный язычок лежит на нижней губе. Держи 5 секунд.", "difficulty": 1 },
        { "id": "k-prep-7",  "word": "качели",             "hint": "Язычок вверх — вниз, вверх — вниз. Следи, чтобы движения были плавными.", "difficulty": 2 },
        { "id": "k-prep-8",  "word": "горбик",             "hint": "Открой рот. Приподними спинку языка — сделай горбик посередине. Кончик внизу.", "difficulty": 2 },
        { "id": "k-prep-9",  "word": "кошечка злится",     "hint": "Выгни спинку языка высоко вверх, как кошка горбит спину. Удержи 5 секунд.", "difficulty": 3 },
        { "id": "k-prep-10", "word": "нёбо-язык",          "hint": "Дотронься кончиком языка до нёба, потом до корня — туда-обратно медленно.", "difficulty": 3 },
        { "id": "k-prep-11", "word": "жевание",            "hint": "Медленно жуй воображаемую жвачку — разогреваем нижнюю челюсть.", "difficulty": 1 },
        { "id": "k-prep-12", "word": "вкусное варенье",    "hint": "Широким языком медленно облизни верхнюю губу слева направо.", "difficulty": 2 },
        { "id": "k-prep-13", "word": "маляр",              "hint": "Широким языком 'красим потолок' — проводи вперёд-назад по нёбу.", "difficulty": 2 },
        { "id": "k-prep-14", "word": "грибок",             "hint": "Язычок плотно 'прилип' к нёбу — как шляпка гриба. Удержи и отпусти с щелчком.", "difficulty": 3 },
        { "id": "k-prep-15", "word": "лошадка",            "hint": "Щёлкай языком — медленно и чётко. Имитируем цокот копыт.", "difficulty": 2 },
        { "id": "k-prep-16", "word": "надуй щёки",         "hint": "Надуй обе щеки, удержи 3 секунды. Потом выпусти воздух.", "difficulty": 1 },
        { "id": "k-prep-17", "word": "барабан",            "hint": "Кончик языка стучит по бугоркам за верхними зубами: д-д-д-д быстро.", "difficulty": 3 },
        { "id": "k-prep-18", "word": "иголочка-лопатка",   "hint": "Чередуй: острый язычок — широкий язычок. По 3 раза каждый.", "difficulty": 2 },
        { "id": "k-prep-19", "word": "часики",             "hint": "Язычок двигается влево-вправо, касаясь уголков рта. Как маятник часов.", "difficulty": 2 }
      ]
    },
    "isolated": {
