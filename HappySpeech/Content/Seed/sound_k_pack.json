      "items": [
        { "id": "k-iso-0",  "word": "к-к-к кукушка",    "hint": "Кукушка кукует: ку-ку-ку. Делай звук К чётко в начале каждого слога.", "difficulty": 1 },
        { "id": "k-iso-1",  "word": "к-к-к капли",       "hint": "Капли дождя стучат: к-к-к — равномерно, как метроном.", "difficulty": 1 },
        { "id": "k-iso-2",  "word": "кх-кх тихо",        "hint": "Тихонько кашляни: кх — корень языка касается нёба.", "difficulty": 2 },
        { "id": "k-iso-3",  "word": "к — пауза — к",     "hint": "Говори к, делай паузу, снова к. Не торопись.", "difficulty": 1 },
        { "id": "k-iso-4",  "word": "к-к-к стук",        "hint": "Стучим молоточком: к-к-к — трижды одинаково.", "difficulty": 1 },
        { "id": "k-iso-5",  "word": "кь-кь-кь мягко",    "hint": "Мягкий [К'] — как маленькая кукушка. Кь-кь-кь тихо.", "difficulty": 2 },
        { "id": "k-iso-6",  "word": "к/кь чередование",  "hint": "Чередуй твёрдый и мягкий: К — Кь — К — Кь.", "difficulty": 3 },
        { "id": "k-iso-7",  "word": "к-к-к быстро",      "hint": "Три удара быстро: ккк — без паузы между ними.", "difficulty": 3 },
        { "id": "k-iso-8",  "word": "к ритм 2-2",        "hint": "Два удара — пауза — два удара: кк — пауза — кк.", "difficulty": 3 },
        { "id": "k-iso-9",  "word": "к ритм 3-1",        "hint": "Три быстрых — один долгий: ккк-к. Чувствуй ритм.", "difficulty": 4 },
        { "id": "k-iso-10", "word": "к тихо-громко",     "hint": "Сначала очень тихо: к... потом всё громче: к! к! К!", "difficulty": 3 },
        { "id": "k-iso-11", "word": "ку-ку часы",        "hint": "Часы бьют ку-ку. Считай удары: ку-ку (два раза).", "difficulty": 2 }
      ]
