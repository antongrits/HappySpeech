    "story": {
      "stageId": "story",
      "note": "Короткие тексты и рассказы со звуком [Г]/[Г'].",
      "items": [
        {
          "id": "g-st-0",
          "word": "Гусь и гусята",
          "hint": "Гусь вёл гусят на луг. Гусята гуляли и клевали траву. Гусь гоготал.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-st-0.m4a"
        },
        {
          "id": "g-st-1",
          "word": "Гроза в горах",
          "hint": "В горах гремел гром. Гром гремел громко. Горы гудели.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-st-1.m4a"
        },
        {
          "id": "g-st-2",
          "word": "Где грибы?",
          "hint": "Гена пошёл в лес. Он глядел под горку. Там был гриб!",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-st-2.m4a"
        },
        {
          "id": "g-st-3",
          "word": "Голубь на горе",
          "hint": "На горе сидел голубь. Голубь гулил. Гора была голубой от неба.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-st-3.m4a"
        },
        {
          "id": "g-st-4",
          "word": "Горошины в горшке",
          "hint": "В горшке варился горох. Горошины прыгали. Горячий пар шёл вверх.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-st-4.m4a"
        },
        {
          "id": "g-st-5",
          "word": "Гитарист Гена",
          "hint": "Гена играл на гитаре. Он играл громко и гордо. Гости хлопали.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-st-5.m4a"
        },
        {
          "id": "g-st-6",
          "word": "Горилла в гостях",
          "hint": "Горилла пришла в гости. Горилла дала гостям груши. Гости обрадовались.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-st-6.m4a"
        },
        {
          "id": "g-st-7",
          "word": "Гусеница на грядке",
          "hint": "Гусеница ползла по грядке. Она грызла горох и гречиху.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-st-7.m4a"
        },
        {
          "id": "g-st-8",
          "word": "Глеб и глобус",
          "hint": "Глеб смотрел на глобус. Он нашёл горы и города. Глеб улыбнулся.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-st-8.m4a"
        },
        {
          "id": "g-st-9",
          "word": "Бегемот и гора",
          "hint": "Бегемот хотел залезть на гору. Но он был большой. Гора была крутая.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-st-9.m4a"
        },
        {
          "id": "g-st-10",
          "word": "Голос в горах",
          "hint": "«Го-го-го!» — крикнул Гена. Горы ответили: «Го-го-го!» Это эхо.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-st-10.m4a"
        },
        {
          "id": "g-st-11",
          "word": "Гречка и горох",
          "hint": "Мама сварила гречку. Папа принёс горох. Вместе — гречка с горохом!",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-st-11.m4a"
        },
        {
          "id": "g-st-12",
          "word": "Гром и молния",
          "hint": "Гром — это звук. Молния — это свет. Сначала видим, потом слышим гром.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-st-12.m4a"
        }
      ]
    }
