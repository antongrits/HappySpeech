          "audio_file": "Audio/Content/G/g-sen-5.m4a"
        },
        {
          "id": "g-sen-6",
          "word": "Лягушка прыгает в болото.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-6.m4a"
        },
        {
          "id": "g-sen-7",
          "word": "В огороде растёт горох.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-7.m4a"
        },
        {
          "id": "g-sen-8",
          "word": "Снег лежит на горе.",
          "difficulty": 2,
          "audio_file": "Audio/Content/G/g-sen-8.m4a"
        },
        {
          "id": "g-sen-9",
          "word": "Глеб нарисовал глобус.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-9.m4a"
        },
        {
          "id": "g-sen-10",
          "word": "Бегемот живёт в тёплых странах.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-10.m4a"
        },
        {
          "id": "g-sen-11",
          "word": "Гречка с маслом очень вкусная.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-11.m4a"
        },
        {
          "id": "g-sen-12",
          "word": "Горилла — большая и сильная обезьяна.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-12.m4a"
        },
        {
          "id": "g-sen-13",
          "word": "По дороге в гору едет вагон.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-13.m4a"
        },
        {
          "id": "g-sen-14",
          "word": "Гена загадал загадку другу.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-14.m4a"
        },
        {
          "id": "g-sen-15",
          "word": "Гусь переплыл большое озеро.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-15.m4a"
        },
        {
          "id": "g-sen-16",
          "word": "Грибники нашли гриб в горах.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-16.m4a"
        },
        {
          "id": "g-sen-17",
          "word": "Голубые горы стоят вдали.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-17.m4a"
        },
        {
          "id": "g-sen-18",
          "word": "Гречневая каша готова.",
          "difficulty": 2,
          "audio_file": "Audio/Content/G/g-sen-18.m4a"
        },
        {
          "id": "g-sen-19",
          "word": "Гарик и Глеб играли в гараже.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-19.m4a"
        },
        {
          "id": "g-sen-20",
          "word": "Голосистый гусь гонит гусят.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-20.m4a"
        },
        {
          "id": "g-sen-21",
          "word": "Горилла грустит в зоопарке.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-21.m4a"
        },
        {
          "id": "g-sen-22",
          "word": "Грузовик едет по дороге в гору.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-22.m4a"
        },
        {
          "id": "g-sen-23",
          "word": "Гусеница ела листья на грядке.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-23.m4a"
        },
        {
          "id": "g-sen-24",
          "word": "Голубь гулял по набережной.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-24.m4a"
        },
        {
          "id": "g-sen-25",
          "word": "Галя гуляла в густом городском парке.",
          "difficulty": 3,
          "audio_file": "Audio/Content/G/g-sen-25.m4a"
        },
        {
          "id": "g-sen-26",
          "word": "Грибники нашли гриб у гнилого пня.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-26.m4a"
        },
        {
          "id": "g-sen-27",
          "word": "Гусь гоготал громко у голубого пруда.",
          "difficulty": 4,
          "audio_file": "Audio/Content/G/g-sen-27.m4a"
        }
      ]
    },
