    "story": {
      "stageId": "story",
      "note": "Тексты с дифференцируемыми парами звуков для чтения и пересказа.",
      "items": [
        { "id": "dwh-st-0",  "word": "Саша и Маша",                    "hint": "Саша и Маша — подруги. Саша носит сумку. Маша носит шапку.", "difficulty": 2 },
        { "id": "dwh-st-1",  "word": "Кошка и оса",                    "hint": "Кошка сидела в саду. Оса летела мимо. Кошка испугалась осы.", "difficulty": 2 },
        { "id": "dwh-st-2",  "word": "Зайка и ёжик",                   "hint": "Зайка прыгал. Ёжик шёл медленно. Зайка ждал ёжика.", "difficulty": 3 },
        { "id": "dwh-st-3",  "word": "Жираф и зебра",                  "hint": "Жираф высокий. Зебра полосатая. Жираф и зебра дружат в зоопарке.", "difficulty": 3 },
        { "id": "dwh-st-4",  "word": "Часы и цветок",                  "hint": "На столе стояли часы. Рядом цвёл цветок. Часы тикали, цветок молчал.", "difficulty": 3 },
        { "id": "dwh-st-5",  "word": "Чайка и цапля",                  "hint": "Чайка летела над морем. Цапля стояла у реки. Они разные птицы.", "difficulty": 3 },
        { "id": "dwh-st-6",  "word": "Сова охотится",                  "hint": "Сова сидела на сосне. Мышка пробежала внизу. Сова поймала мышку.", "difficulty": 3 },
        { "id": "dwh-st-7",  "word": "Дождик и зонт",                  "hint": "Пошёл дождь. Зина взяла зонт. Зонт защитил её от дождя.", "difficulty": 2 },
        { "id": "dwh-st-8",  "word": "Шуба и сапоги",                  "hint": "Зимой надевают шубу и сапоги. Шуба греет. Сапоги не промокают.", "difficulty": 2 },
        { "id": "dwh-st-9",  "word": "Черепаха и цыплёнок",            "hint": "Цыплёнок бегал быстро. Черепаха ползла медленно. Они шли в цирк.", "difficulty": 3 },
        { "id": "dwh-st-10", "word": "Змея и жаба",                   "hint": "Змея шипела. Жаба квакала. Они не дружили в болоте.", "difficulty": 4 },
        { "id": "dwh-st-11", "word": "Соня и Жора",                    "hint": "Соня пила сок. Жора ел кашу. Потом они пошли гулять вместе.", "difficulty": 3 },
        { "id": "dwh-st-12", "word": "Снегурочка и Жар-птица",         "hint": "Снегурочка любила снег и мороз. Жар-птица любила огонь и жар.", "difficulty": 4 },
        { "id": "dwh-st-13", "word": "Цветочный чай",                  "hint": "Бабушка заварила цветочный чай. Чай получился ароматным. Все пили чай.", "difficulty": 3 },
        { "id": "dwh-st-14", "word": "Сушёные ягоды",                  "hint": "Маша сушила ягоды. Шишки тоже сушились рядом. В шкафу было сухо.", "difficulty": 4 },
        { "id": "dwh-st-15", "word": "Жёлудь и желудь",               "hint": "Зайка нашёл жёлудь. Жёлудь упал с дуба. Зайка понёс жёлудь домой.", "difficulty": 3 },
        { "id": "dwh-st-16", "word": "Зонтик и шляпа",                "hint": "У Зины зонтик. У Шуры шляпа. Зина с зонтиком. Шура в шляпе.", "difficulty": 2 },
        { "id": "dwh-st-17", "word": "Щука и чайка",                  "hint": "Щука живёт в реке. Чайка летает над рекой. Щука и чайка — соседки.", "difficulty": 3 },
        { "id": "dwh-st-18", "word": "Цыплята и черепашки",           "hint": "Цыплята бегали быстро. Черепашки ползли медленно. Цирк смеялся.", "difficulty": 3 },
        { "id": "dwh-st-19", "word": "Миска и кошка",                 "hint": "Кошка нашла миску. В миске было молоко. Кошка выпила молоко.", "difficulty": 2 },
        { "id": "dwh-st-20", "word": "Шуршание в саду",               "hint": "В саду что-то шуршало. Это была мышка. Мышка сидела за кустом.", "difficulty": 3 },
        { "id": "dwh-st-21", "word": "Жираф и заяц",                  "hint": "Жираф высокий. Заяц прыгучий. Жираф смотрел сверху, заяц — снизу.", "difficulty": 3 },
        { "id": "dwh-st-22", "word": "Чай и цветы",                   "hint": "Цветы росли в саду. Из цветов сделали чай. Чай пахнет цветами.", "difficulty": 2 },
        { "id": "dwh-st-23", "word": "Снег и жара",                   "hint": "Зимой был снег. Летом — жара. Зима и лето — совсем разные.", "difficulty": 2 },
        { "id": "dwh-st-24", "word": "Сушки и плюшки",               "hint": "Бабушка испекла сушки и плюшки. Сушки твёрдые. Плюшки мягкие.", "difficulty": 2 },
        { "id": "dwh-st-25", "word": "Журавль и цапля",               "hint": "Журавль летел высоко. Цапля стояла в воде. Оба — красивые птицы.", "difficulty": 3 },
        { "id": "dwh-st-26", "word": "Зимний шарф",                   "hint": "Зима пришла. Соня надела шарф. Шарф был синий и пушистый.", "difficulty": 2 },
        { "id": "dwh-st-27", "word": "Жук и оса",                    "hint": "Жук жужжал. Оса жалила. Жук и оса — оба насекомые.", "difficulty": 2 },
        { "id": "dwh-st-28", "word": "Часы и цифры",                 "hint": "На часах есть цифры. Цифры показывают время. Часы идут — цифры меняются.", "difficulty": 3 },
        { "id": "dwh-st-29", "word": "Сажа и каша",                  "hint": "Сажа — чёрная. Каша — вкусная. Одна буква разная — С или К!", "difficulty": 2 }
      ]
