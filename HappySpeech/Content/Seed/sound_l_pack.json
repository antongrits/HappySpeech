        { "id": "l-sen-16", "word": "Голубой велосипед стоит у школы.",           "difficulty": 3 },
        { "id": "l-sen-17", "word": "Белочка нашла желудь под дубом.",            "difficulty": 3 },
        { "id": "l-sen-18", "word": "Холодный ливень прибил листья к земле.",     "difficulty": 4 },
        { "id": "l-sen-19", "word": "Лётчики пролетели над полем.",               "difficulty": 3 },
        { "id": "l-sen-20", "word": "Лягушки квакают всю ночь у болота.",         "difficulty": 4 },
        { "id": "l-sen-21", "word": "Лена любит лепить из солёного теста.",       "difficulty": 4 },
        { "id": "l-sen-22", "word": "Слон и лев — самые большие в зоопарке.",     "difficulty": 4 },
