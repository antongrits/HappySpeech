        { "id": "l-st-2",  "word": "Клала Клава лук на полку — кликни Клаву, сняла полку.", "hint": "Следи за Л в каждом слове.", "difficulty": 4 },
        { "id": "l-st-3",  "word": "Лев Лёлик лежал и лениво лизал лимон.",              "hint": "Все Л мягкие и твёрдые — слушай разницу!", "difficulty": 4 },
        { "id": "l-st-4",  "word": "На лугу под луной стоит лопата — это луговая лопата.", "hint": "Нараспев, как сказка.", "difficulty": 3 },
        { "id": "l-st-5",  "word": "Лось у ели полетел — нет, лось у ели лёг и ел.",     "hint": "Слушай — где Л твёрдый, где мягкий.", "difficulty": 3 },
        { "id": "l-st-6",  "word": "Ела-ела Маша мёл — нет: мела, мела — и стол блестел.",  "hint": "Финальный Л — чётко!", "difficulty": 3 },
        { "id": "l-st-7",  "word": "Белый снег летит, летит — лёгкий, лёгкий — на лёд.",  "hint": "Плавно, как снежинки.", "difficulty": 3 },
        { "id": "l-st-8",  "word": "Лена ела булку, Лёша лепил луну — двое лепили лодку.", "hint": "Два раза подряд.", "difficulty": 4 },
        { "id": "l-st-9",  "word": "Слева лес, слева луг — слева слышен голос вслух.",    "hint": "Стечение СЛ — особенно следи!", "difficulty": 5 }
      ]
