rules_version = '2';

// HappySpeech Firestore Security Rules
// Version 1.1 - 2026-04-22 (M1 — sprint backend-dev-infra)
// Contract source: .claude/team/api-contracts.md + M1.3 plan
//
// Changes v1.1:
//   - isAdmin() now checks custom claim `request.auth.token.admin == true`
//     (was: /users/{uid}.role == 'admin' — kept as fallback)
//   - isOwnerParent() helper — specialist reads child only if linked AND
//     parent granted consent via /users/{uid}/children/{cid}.consent.specialistRead == true
//   - added /users/{uid}/children/{cid}/rewards/{rewardId}
//   - added /users/{uid}/children/{cid}/routes/{dateStr}
//   - added /users/{uid}/children/{cid}/weekly_reports/{dateStr}
//   - added /specialists/{sid}/assignments/{assignmentId}
//   - added /content/packs/{packId} and /content/manifest
//   - added /audits/{auditId} — append-only audit log, admin read

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin — primary source: custom claim. Fallback: users/{uid}.role == 'admin'.
    function isAdmin() {
      return isSignedIn()
        && (
          (request.auth.token.admin == true)
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    function hasRole(role) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isParent() {
      return hasRole('parent');
    }

    function isSpecialist() {
      return hasRole('specialist');
    }

    function specialistLinkedToChild(childId) {
      return isSignedIn()
        && isSpecialist()
        && exists(/databases/$(database)/documents/specialists/$(request.auth.uid))
        && childId in get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.linkedChildIds;
    }

    // Specialist may read a child only if linked AND the parent has explicitly
    // granted consent (child doc must have consent.specialistRead == true).
    function isOwnerParent(userId, childId) {
      return isSignedIn()
        && specialistLinkedToChild(childId)
        && exists(/databases/$(database)/documents/users/$(userId)/children/$(childId))
        && get(/databases/$(database)/documents/users/$(userId)/children/$(childId)).data.consent.specialistRead == true;
    }

    function hasFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    function isValidTimestamp(value) {
      return value is timestamp;
    }

    function isValidString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    // ------------------------------------------------------------------
    // /users/{userId}
    // ------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && hasFields(request.resource.data, ['uid', 'email', 'role', 'createdAt'])
        && request.resource.data.uid == userId
        && request.resource.data.role in ['parent', 'specialist', 'admin']
        && isValidString(request.resource.data.email, 254)
        && isValidTimestamp(request.resource.data.createdAt);
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;
      allow delete: if isOwner(userId) || isAdmin();

      // ------------------------------------------------------------------
      // /users/{userId}/children/{childId}
      // ------------------------------------------------------------------

      match /children/{childId} {
        allow read: if isOwner(userId)
          || isAdmin()
          || isOwnerParent(userId, childId);

        allow create: if isOwner(userId)
          && hasFields(request.resource.data, ['id', 'name', 'age', 'createdAt'])
          && isValidString(request.resource.data.name, 50)
          && request.resource.data.age is int
          && request.resource.data.age >= 5
          && request.resource.data.age <= 8
          && isValidTimestamp(request.resource.data.createdAt);

        allow update: if (isOwner(userId) || isOwnerParent(userId, childId))
          && request.resource.data.id == resource.data.id
          && request.resource.data.age is int
          && request.resource.data.age >= 5
          && request.resource.data.age <= 8;

        allow delete: if isOwner(userId) || isAdmin();

        // ------------------------------------------------------------------
        // /users/{userId}/children/{childId}/sessions/{sessionId}
        // ------------------------------------------------------------------

        match /sessions/{sessionId} {
          allow read: if isOwner(userId)
            || isAdmin()
            || isOwnerParent(userId, childId);

          allow create: if (isOwner(userId) || isOwnerParent(userId, childId))
            && hasFields(request.resource.data, [
              'id', 'childId', 'date', 'templateType',
              'targetSound', 'stage', 'durationSeconds',
              'totalAttempts', 'correctAttempts'
            ])
            && request.resource.data.durationSeconds is int
            && request.resource.data.durationSeconds > 0
            && request.resource.data.totalAttempts is int
            && request.resource.data.totalAttempts >= 0
            && request.resource.data.correctAttempts is int
            && request.resource.data.correctAttempts >= 0
            && request.resource.data.correctAttempts <= request.resource.data.totalAttempts
            && isValidString(request.resource.data.templateType, 64)
            && isValidString(request.resource.data.targetSound, 8)
            && isValidString(request.resource.data.stage, 32);

          // Sessions are immutable once written, except specialist can add annotations
          allow update: if (isAdmin() || isOwnerParent(userId, childId))
            && request.resource.data.id == resource.data.id
            && request.resource.data.childId == resource.data.childId;

          allow delete: if isOwner(userId) || isAdmin();

          // ------------------------------------------------------------------
          // /users/{userId}/children/{childId}/sessions/{sessionId}/attempts/{attemptId}
          // ------------------------------------------------------------------

          match /attempts/{attemptId} {
            allow read: if isOwner(userId)
              || isAdmin()
              || isOwnerParent(userId, childId);

            allow create: if (isOwner(userId) || isOwnerParent(userId, childId))
              && hasFields(request.resource.data, [
                'id', 'word', 'asrTranscript', 'asrScore',
                'pronunciationScore', 'isCorrect', 'timestamp'
              ])
              && request.resource.data.asrScore is number
              && request.resource.data.asrScore >= 0.0
              && request.resource.data.asrScore <= 1.0
              && request.resource.data.pronunciationScore is number
              && request.resource.data.pronunciationScore >= 0.0
              && request.resource.data.pronunciationScore <= 1.0
              && request.resource.data.isCorrect is bool
              && isValidString(request.resource.data.word, 64)
              && isValidTimestamp(request.resource.data.timestamp);

            // Specialist can override score (manualScore field)
            allow update: if (isAdmin() || isOwnerParent(userId, childId))
              && request.resource.data.id == resource.data.id
              && request.resource.data.manualScore is number
              && request.resource.data.manualScore >= -1.0
              && request.resource.data.manualScore <= 1.0;

            allow delete: if isOwner(userId) || isAdmin();
          }
        }

        // ------------------------------------------------------------------
        // /users/{userId}/children/{childId}/progress/{soundTarget}
        // Computed server-side — clients read only.
        // ------------------------------------------------------------------

        match /progress/{soundTarget} {
          allow read: if isOwner(userId)
            || isAdmin()
            || isOwnerParent(userId, childId);
          allow write: if isAdmin();
        }

        // ------------------------------------------------------------------
        // /users/{userId}/children/{childId}/plans/{planId}
        // ------------------------------------------------------------------

        match /plans/{planId} {
          allow read: if isOwner(userId)
            || isAdmin()
            || isOwnerParent(userId, childId);
          allow create, update: if (isOwner(userId) || isOwnerParent(userId, childId))
            && hasFields(request.resource.data, ['id', 'childId', 'date'])
            && isValidTimestamp(request.resource.data.date);
          allow delete: if isOwner(userId) || isAdmin();
        }

        // ------------------------------------------------------------------
        // /users/{userId}/children/{childId}/reports/{reportId}
        // Generated by Cloud Functions — clients read only.
        // ------------------------------------------------------------------

        match /reports/{reportId} {
          allow read: if isOwner(userId)
            || isAdmin()
            || isOwnerParent(userId, childId);
          allow write: if isAdmin();
        }

        // ------------------------------------------------------------------
        // /users/{userId}/children/{childId}/weekly_reports/{dateStr}
        // Generated by scheduled Cloud Function sendWeeklyReport.
        // Clients read only, admin writes.
        // ------------------------------------------------------------------

        match /weekly_reports/{dateStr} {
          allow read: if isOwner(userId)
            || isAdmin()
            || isOwnerParent(userId, childId);
          allow write: if isAdmin();
        }

        // ------------------------------------------------------------------
        // /users/{userId}/children/{childId}/rewards/{rewardId}
        // ------------------------------------------------------------------

        match /rewards/{rewardId} {
          allow read: if isOwner(userId)
            || isAdmin()
            || isOwnerParent(userId, childId);
          allow create: if isOwner(userId)
            && hasFields(request.resource.data, ['id', 'type', 'earnedAt'])
            && isValidString(request.resource.data.type, 64)
            && isValidTimestamp(request.resource.data.earnedAt);
          allow update: if isOwner(userId)
            && request.resource.data.id == resource.data.id;
          allow delete: if isOwner(userId) || isAdmin();
        }

        // ------------------------------------------------------------------
        // /users/{userId}/children/{childId}/routes/{dateStr}
        // Daily adaptive route — produced client-side.
        // ------------------------------------------------------------------

        match /routes/{dateStr} {
          allow read: if isOwner(userId)
            || isAdmin()
            || isOwnerParent(userId, childId);
          allow create, update: if isOwner(userId)
            && hasFields(request.resource.data, ['dateStr', 'childId', 'items']);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }
    }

    // ------------------------------------------------------------------
    // /specialists/{specialistId}
    // ------------------------------------------------------------------

    match /specialists/{specialistId} {
      allow read: if isOwner(specialistId) || isAdmin();
      allow create: if isOwner(specialistId)
        && hasFields(request.resource.data, ['uid', 'email', 'createdAt'])
        && request.resource.data.uid == specialistId;
      allow update: if isOwner(specialistId) || isAdmin();
      allow delete: if isAdmin();

      // ----------------------------------------------------------------
      // /specialists/{sid}/assignments/{assignmentId}
      // Parent-granted access link: specialist ↔ child.
      // Parent creates; specialist and admin can read; specialist cannot modify.
      // ----------------------------------------------------------------

      match /assignments/{assignmentId} {
        allow read: if isOwner(specialistId) || isAdmin();
        // Only admin can create/update/delete — assignments are issued by
        // Cloud Function after parent confirms consent.
        allow write: if isAdmin();
      }
    }

    // ------------------------------------------------------------------
    // /content/* — shared content (packs, exercises, words, manifest)
    // Public read for authenticated users, admin write.
    // ------------------------------------------------------------------

    match /content/packs/{packId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /content/manifest {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /contentPacks/{packId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /content/{contentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // /audits/{auditId} — append-only audit log (admin-only read).
    // Created by Cloud Functions only; never read/written by clients.
    // ------------------------------------------------------------------

    match /audits/{auditId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Default deny for anything else
    // ------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
