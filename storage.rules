rules_version = '2';

// HappySpeech Firebase Storage Security Rules
// Version 1.0 - 2026-04-22
// Contract source: .claude/team/api-contracts.md section 4

service firebase.storage {
  match /b/{bucket}/o {

    // ------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSpecialist() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'specialist';
    }

    function isValidAudio() {
      // Max 20MB per recording; m4a/wav/mp3/aac only
      return request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('audio/.*'));
    }

    function isValidImage() {
      // Max 5MB per image; png/jpg only
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|jpg|webp)');
    }

    // ------------------------------------------------------------------
    // /content/{contentPackFile}
    // Downloadable content packs (shared across all users)
    // ------------------------------------------------------------------

    match /content/{contentPackFile=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // /models/{modelFile}
    // ML model distribution (read-only for clients)
    // ------------------------------------------------------------------

    match /models/{modelFile=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // /users/{userId}/avatars/{fileName}
    // Parent profile avatars
    // ------------------------------------------------------------------

    match /users/{userId}/avatars/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ------------------------------------------------------------------
    // /users/{userId}/children/{childId}/avatars/{fileName}
    // Child profile avatars (optional pre-made only)
    // ------------------------------------------------------------------

    match /users/{userId}/children/{childId}/avatars/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ------------------------------------------------------------------
    // /users/{userId}/children/{childId}/attempts/{attemptId}/audio.m4a
    // Child attempt recordings — parent read only (COPPA-sensitive)
    // ------------------------------------------------------------------

    match /users/{userId}/children/{childId}/recordings/{attemptId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidAudio();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/children/{childId}/attempts/{attemptId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidAudio();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ------------------------------------------------------------------
    // /users/{userId}/exports/{fileName}
    // Parent-requested data exports (parent-only)
    // ------------------------------------------------------------------

    match /users/{userId}/exports/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); // Generated by Cloud Functions only
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ------------------------------------------------------------------
    // Default deny for anything else
    // ------------------------------------------------------------------

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
