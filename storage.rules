rules_version = '2';

// HappySpeech Firebase Storage Security Rules
// Version 1.1 - 2026-04-22 (M1 — sprint backend-dev-infra)
// Contract source: .claude/team/api-contracts.md section 4 + M1.3 plan
//
// Changes v1.1:
//   - isAdmin() now honours custom claim `request.auth.token.admin == true`
//     (Firestore role fallback kept)
//   - shared content tree expanded: /audio/{ui,lyalya,content,refs}, /illustrations, /3d, /animations, /models
//   - /exports/{uid}/** owner-only (read+delete); writes only by admin (Cloud Function)
//   - /uploads/users/{uid}/** owner write with size and mime validation

service firebase.storage {
  match /b/{bucket}/o {

    // ------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && (
          (request.auth.token.admin == true)
          || (
            firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    function isSpecialist() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'specialist';
    }

    // Max 20 MB per audio upload; audio/* only.
    function isValidAudio() {
      return request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    // Max 10 MB user upload (image or audio).
    function isValidUserUpload() {
      return request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/(png|jpeg|jpg|webp)')
          || request.resource.contentType.matches('audio/.*')
        );
    }

    // Max 5 MB per image; png/jpg/webp only.
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|jpg|webp)');
    }

    // ------------------------------------------------------------------
    // Shared read-only content (all signed-in users can read, admin writes)
    // ------------------------------------------------------------------

    // UI sounds
    match /audio/ui/{file=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Mascot "Ляля" voice lines
    match /audio/lyalya/{file=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Content audio per sound (word prompts etc.)
    match /audio/content/{sound}/{file=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reference pronunciations (teacher model voice)
    match /audio/refs/{sound}/{file=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Generic /audio/** fallback — read-only for authenticated.
    match /audio/{path=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ML models (WhisperKit, local LLM)
    match /models/{path=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Illustrations
    match /illustrations/{category}/{file=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 3D models (USDZ etc.)
    match /3d/{file=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Animations (Rive, Lottie)
    match /animations/{file=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Downloadable content packs
    match /content/{path=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Per-user private storage
    // ------------------------------------------------------------------

    // User avatars
    match /users/{userId}/avatars/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Child avatars
    match /users/{userId}/children/{childId}/avatars/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Child attempt recordings (COPPA-sensitive — parent-only)
    match /users/{userId}/children/{childId}/recordings/{attemptId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidAudio();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/children/{childId}/attempts/{attemptId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidAudio();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Parent-requested exports (GDPR) — written by Cloud Functions, owner reads/deletes.
    match /users/{userId}/exports/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Alias path used by some clients — same semantics
    match /exports/{userId}/{file=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // General user uploads (avatars, screenshots, etc.) — <10MB, image/audio only
    match /uploads/users/{userId}/{file=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidUserUpload();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ------------------------------------------------------------------
    // Default deny for anything else
    // ------------------------------------------------------------------

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
